# Enhanced JWT Wrapper - Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# JWT SECRETS (REQUIRED - CRITICAL)
# =============================================================================
# Generate strong secrets: python -c "import secrets; print(secrets.token_urlsafe(64))"
# MUST be different and at least 32 characters each

JWT_SECRET=your-super-secret-access-token-key-minimum-32-characters-change-this
JWT_REFRESH_SECRET=your-different-refresh-token-key-minimum-32-characters-change-this


# =============================================================================
# TOKEN EXPIRATION (in seconds)
# =============================================================================
# Recommended: 15 minutes for access, 7 days for refresh
# High security: 5 minutes for access, 1 hour for refresh

JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800


# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Required for token revocation and rate limiting

JWT_USE_REDIS=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0


# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Strict mode: fail if Redis unavailable (recommended for production)
# Rotate refresh: automatically rotate refresh tokens on use (recommended)

JWT_STRICT_MODE=true
JWT_ROTATE_REFRESH=true
JWT_ALGORITHM=HS256


# =============================================================================
# JWT CLAIMS
# =============================================================================
# Customize issuer and audience for your application

JWT_ISSUER=your-company-name
JWT_AUDIENCE=your-app-name


# =============================================================================
# CLOCK SKEW TOLERANCE (in seconds)
# =============================================================================
# Allow for clock drift between servers (default: 30 seconds)

JWT_CLOCK_SKEW=30


# =============================================================================
# REDIS KEY PREFIX
# =============================================================================
# Customize Redis key namespace to avoid conflicts

JWT_BLACKLIST_PREFIX=jwt:blacklist


# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# For local development only - DO NOT USE IN PRODUCTION

# DEV_MODE=true
# JWT_USE_REDIS=false
# JWT_STRICT_MODE=false
# LOG_LEVEL=DEBUG


# =============================================================================
# PRODUCTION SETTINGS (uncomment for production)
# =============================================================================

# JWT_STRICT_MODE=true
# JWT_USE_REDIS=true
# REDIS_HOST=redis.production.example.com
# REDIS_PASSWORD=your-redis-password
# LOG_LEVEL=INFO


# =============================================================================
# MONITORING (optional)
# =============================================================================

# SENTRY_DSN=https://your-sentry-dsn
# CLOUDWATCH_NAMESPACE=YourApp/JWT
# DATADOG_API_KEY=your-datadog-key


# =============================================================================
# RATE LIMITING (Enhanced wrapper only)
# =============================================================================

# REFRESH_RATE_LIMIT_ENABLED=true
# REFRESH_RATE_LIMIT_COUNT=10
# REFRESH_RATE_LIMIT_WINDOW=3600


# =============================================================================
# DEVICE BINDING (Enhanced wrapper only)
# =============================================================================

# DEVICE_BINDING_ENABLED=false
# DEVICE_ID_HEADER=X-Device-ID


# =============================================================================
# PAYLOAD SECURITY (Enhanced wrapper only)
# =============================================================================

# MAX_PAYLOAD_SIZE_BYTES=1024
# FORBIDDEN_PAYLOAD_KEYS=password,ssn,credit_card,api_key
